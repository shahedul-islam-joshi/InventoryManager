@model InventoryManager.Models.ViewModels.InventoryDetailsViewModel
@using InventoryManager.Data
@inject ApplicationDbContext Db
@{
    // Fields tab — shows the inventory's custom field definitions
    // and allows the owner to add / remove them.
    var fields = Db.InventoryFields
        .Where(f => f.InventoryId == Model.Inventory.Id)
        .OrderBy(f => f.Order)
        .ToList();
}

<div class="p-2">
    <h4>Custom Fields</h4>
    <p class="text-muted">
        Define up to 3 fields per type (Text, Number, Boolean, Date).
        The field titles appear as column headers in the Items table.
    </p>

    @if (fields.Any())
    {
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Type</th><th>Slot</th><th>Title</th><th>Show in table?</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in fields)
                {
                    <tr>
                        <td>@f.FieldType</td>
                        <td>@f.SlotIndex</td>
                        <td>@f.Title</td>
                        <td>@(f.ShowInTable ? "✓" : "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">No custom fields defined yet. Items will show Name and Description only.</div>
    }

    @if (Model.IsOwner)
    {
        <div class="mt-3">
            <p class="text-muted small">
                To manage fields, edit individual slots via the Settings tab or use the API.
                Full field management UI coming soon.
            </p>
        </div>
    }
</div>
