@model InventoryManager.Models.ViewModels.InventoryEditVM
@{
    ViewData["Title"] = "Edit Inventory";
}

<h1>Edit Inventory</h1>
<hr />

@* Auto-save status badge styles — scoped to this page only *@
<style>
    .autosave-status           { font-size: 0.85rem; padding: 0.2rem 0.6rem; border-radius: 4px; transition: opacity 0.4s; }
    .autosave-status.as-saving { background: #fff3cd; color: #856404; }
    .autosave-status.as-saved  { background: #d1e7dd; color: #0a3622; }
    .autosave-status.as-conflict,
    .autosave-status.as-error  { background: #f8d7da; color: #58151c; font-weight: 600; }
</style>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" method="post" id="autosave-form">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Version" />

            @* Status badge — updated in real time by inventory-autosave.js *@
            <div class="mb-2">
                <span id="autosave-status" class="autosave-status"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Category" class="form-label"></label>
                <input asp-for="Category" class="form-control" />
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ImageUrl" class="form-label">Image URL (optional)</label>
                <input asp-for="ImageUrl" class="form-control" type="url" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Tags" class="form-label">Tags (comma-separated)</label>
                <input asp-for="Tags" class="form-control" placeholder="books, literature, sci-fi" />
            </div>

            <div class="mb-3 form-check">
                <input asp-for="IsPublic" class="form-check-input" type="checkbox" />
                <label asp-for="IsPublic" class="form-check-label">Publicly visible</label>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/inventory-autosave.js" asp-append-version="true"></script>
}

