@model List<InventoryManager.Models.Domain.Inventory>

@{
    ViewData["Title"] = "Home";
    var tagCloud = ViewBag.TagCloud as List<(InventoryManager.Models.Domain.Tag Tag, int Count)> ?? new();
}

<div class="row mt-4">
    <div class="col-lg-8">
        <h2 class="mb-3">Latest Inventories</h2>

        @if (!Model.Any())
        {
            <div class="alert alert-info">No public inventories yet. <a asp-controller="Inventory" asp-action="Create">Create the first one!</a></div>
        }
        else
        {
            <div class="list-group">
                @foreach (var inv in Model)
                {
                    <a asp-controller="Inventory" asp-action="Details" asp-route-id="@inv.Id"
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-start py-3">
                        <div>
                            <strong>@inv.Title</strong>
                            <div class="text-muted small">@inv.Category &mdash; @inv.CreatedAt.ToShortDateString()</div>
                            @if (!string.IsNullOrWhiteSpace(inv.Description))
                            {
                                <p class="mb-0 mt-1 text-secondary small">@inv.Description[..Math.Min(120, inv.Description.Length)]@(inv.Description.Length > 120 ? "…" : "")</p>
                            }
                            @foreach (var it in inv.InventoryTags)
                            {
                                <span class="badge bg-secondary me-1">@it.Tag.Name</span>
                            }
                        </div>
                        <span class="badge bg-@(inv.IsPublic ? "success" : "secondary") ms-2">@(inv.IsPublic ? "Public" : "Private")</span>
                    </a>
                }
            </div>

            <div class="mt-3">
                <a asp-controller="Inventory" asp-action="Index" class="btn btn-outline-primary">View all inventories</a>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <h2 class="mb-3">Tag Cloud</h2>
        @if (tagCloud.Any())
        {
            <div class="d-flex flex-wrap gap-2">
                @foreach (var (tag, count) in tagCloud)
                {
                    <a asp-controller="Search" asp-action="Results" asp-route-q="@tag.Name"
                       class="badge text-bg-primary text-decoration-none"
                       style="font-size: @(0.7 + (count * 0.15))rem">
                        @tag.Name <span class="badge bg-light text-dark ms-1">@count</span>
                    </a>
                }
            </div>
        }
        else
        {
            <p class="text-muted">No tags yet.</p>
        }

        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="mt-4">
                <a asp-controller="Inventory" asp-action="Create" class="btn btn-primary w-100">
                    + New Inventory
                </a>
            </div>
        }
    </div>
</div>
