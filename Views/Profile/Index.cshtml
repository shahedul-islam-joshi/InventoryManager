@model InventoryManager.Models.ViewModels.ProfileVM
@{
    ViewData["Title"] = $"{Model.User.UserName}'s Profile";
}

<div class="row mt-4">
    <div class="col-md-3">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">@Model.User.UserName</h5>
            </div>
            <div class="card-body">
                <p class="mb-1"><strong>Email:</strong> @Model.User.Email</p>
                <p class="mb-0 text-muted small">Member since @Model.User.LockoutEnd?.ToString("yyyy") or earlier</p>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <h3>Owned Inventories <span class="badge bg-primary">@Model.OwnedInventories.Count</span></h3>

        @if (!Model.OwnedInventories.Any())
        {
            <p class="text-muted">No inventories yet.</p>
        }
        else
        {
            <div class="list-group mb-4">
                @foreach (var inv in Model.OwnedInventories)
                {
                    <a asp-controller="Inventory" asp-action="Details" asp-route-id="@inv.Id"
                       class="list-group-item list-group-item-action d-flex justify-content-between">
                        <div>
                            <strong>@inv.Title</strong>
                            <div class="text-muted small">@inv.Category — @inv.CreatedAt.ToShortDateString()</div>
                        </div>
                        <span class="badge bg-@(inv.IsPublic ? "success" : "secondary") align-self-center">@(inv.IsPublic ? "Public" : "Private")</span>
                    </a>
                }
            </div>
        }

        @if (Model.SharedInventories.Any())
        {
            <h3>Shared with me <span class="badge bg-secondary">@Model.SharedInventories.Count</span></h3>
            <div class="list-group">
                @foreach (var inv in Model.SharedInventories)
                {
                    <a asp-controller="Inventory" asp-action="Details" asp-route-id="@inv.Id"
                       class="list-group-item list-group-item-action">
                        <strong>@inv.Title</strong>
                        <div class="text-muted small">@inv.Category</div>
                    </a>
                }
            </div>
        }
    </div>
</div>
