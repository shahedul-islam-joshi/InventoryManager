@model InventoryManager.Models.ViewModels.ItemEditVM
@{
    ViewData["Title"] = "Edit Item";
}

<h1>Edit Item</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="InventoryId" />
            <input type="hidden" asp-for="Version" />

            @if (!string.IsNullOrWhiteSpace(Model.CustomId))
            {
                <div class="mb-3">
                    <label class="form-label">Custom ID</label>
                    <input type="text" class="form-control" value="@Model.CustomId" readonly />
                    <div class="form-text">Custom ID cannot be changed after creation.</div>
                </div>
            }

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-controller="Inventory" asp-action="Details" asp-route-id="@Model.InventoryId"
                   class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
